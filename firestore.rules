rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────── Yardımcı Fonksiyonlar ─────────

    // Giriş yapmış kullanıcının dokümanını getir
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Kullanıcı giriş yapmış mı?
    function isSignedIn() {
      return request.auth != null;
    }

    // Kullanıcı bu şirkete ait mi?
    function belongsToCompany(companyId) {
      return isSignedIn() && getUserData().companyId == companyId;
    }

    // Uygulamadaki mevcut şema: companyName üzerinden şirket bağlama
    function belongsToCompanyName(companyName) {
      return isSignedIn() && getUserData().companyName == companyName;
    }

    // Kullanıcının rolü verilen listede mi?
    function hasAnyRole(companyId, roles) {
      return belongsToCompany(companyId) && getUserData().role in roles;
    }

    // Owner veya Admin mi?
    function isAdminOrOwner(companyId) {
      return hasAnyRole(companyId, ['owner', 'admin']);
    }

    // ───────── Veri Doğrulama Fonksiyonları ─────────

    // Veri bir string mi ve boş değil mi?
    function isNonEmptyString(val) {
      return val is string && val.size() > 0;
    }

    // Geçerli bir rol mü?
    function isValidRole(role) {
      return role in ['owner', 'admin', 'manager', 'technician', 'employee'];
    }

    // Şirket ID'si mevcut mu ve doğru mu?
    function isValidCompanyId(data) {
      return isNonEmptyString(data.companyId);
    }

    // ───────── users Koleksiyonu ─────────
    // Her kullanıcı kendi profilini okuyabilir.
    // Şirket yöneticileri (manager/admin/owner) kendi şirketindeki aktif çalışanları görebilir.
    // Pasif çalışanları sadece yönetici (manager/admin/owner) görebilir.
    // Güncelleme: kendisi veya şirketinin manager/admin/owner'ı yapabilir.
    // Oluşturma/silme: sadece backend (Admin SDK / Cloud Functions).
    match /users/{uid} {
      allow read: if isSignedIn() && (
        // always allow self
        request.auth.uid == uid ||
        // company managers can read within their companyName, but inactive only for managers
        (
          belongsToCompanyName(resource.data.companyName) &&
          getUserData().role in ['owner', 'admin', 'manager']
        )
      );

      allow update: if isSignedIn() &&
        (
          request.auth.uid == uid ||
          (
            belongsToCompanyName(resource.data.companyName) &&
            getUserData().role in ['owner', 'admin', 'manager']
          )
        ) &&
        (
          // allow limited profile fields + soft-delete fields
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name',
            'phone',
            'role',
            'companyId',
            'companyName',
            'isActive',
            'deactivatedAt',
            'deactivatedBy',
            'deactivatedReason'
          ])
        ) &&
        (request.resource.data.role == null || isValidRole(request.resource.data.role));
      allow create, delete: if false;
    }

    // ───────── companies Koleksiyonu ─────────
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow update: if isAdminOrOwner(companyId);
      allow create, delete: if false; // Backend tarafından yönetilir

      // ── staff alt koleksiyonu ──
      match /staff/{staffUid} {
        allow read: if belongsToCompany(companyId);
        allow write: if isAdminOrOwner(companyId);
      }
    }

    // ───────── customers Koleksiyonu ─────────
    match /customers/{customerId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create: if isSignedIn() &&
        belongsToCompany(request.resource.data.companyId) &&
        hasAnyRole(request.resource.data.companyId, ['owner', 'admin', 'technician']) &&
        isNonEmptyString(request.resource.data.name) &&
        isValidCompanyId(request.resource.data);
      allow update: if belongsToCompany(resource.data.companyId) &&
        hasAnyRole(resource.data.companyId, ['owner', 'admin', 'technician']) &&
        (request.resource.data.name == null || isNonEmptyString(request.resource.data.name));
      allow delete: if isAdminOrOwner(resource.data.companyId);
    }

    // ───────── tickets Koleksiyonu ─────────
    match /tickets/{ticketId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create: if isSignedIn() &&
        belongsToCompany(request.resource.data.companyId) &&
        hasAnyRole(request.resource.data.companyId, ['owner', 'admin', 'technician']);
      allow update: if belongsToCompany(resource.data.companyId) &&
        hasAnyRole(resource.data.companyId, ['owner', 'admin', 'technician']);
      allow delete: if isAdminOrOwner(resource.data.companyId);

      // ── workLogs alt koleksiyonu ──
      match /workLogs/{logId} {
        allow read: if belongsToCompany(
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.companyId
        );
        allow create: if isSignedIn() &&
          belongsToCompany(request.resource.data.companyId) &&
          hasAnyRole(request.resource.data.companyId, ['owner', 'admin', 'technician']);
        allow update, delete: if isAdminOrOwner(resource.data.companyId);
      }
    }

    // ───────── inventory Koleksiyonu (Opsiyonel) ─────────
    match /inventory/{itemId} {
      allow read: if belongsToCompany(resource.data.companyId);
      allow create: if isSignedIn() &&
        belongsToCompany(request.resource.data.companyId) &&
        isAdminOrOwner(request.resource.data.companyId);
      allow update: if belongsToCompany(resource.data.companyId) &&
        hasAnyRole(resource.data.companyId, ['owner', 'admin', 'technician']);
      allow delete: if isAdminOrOwner(resource.data.companyId);
    }
    // ───────── audit_logs Koleksiyonu ─────────
    match /audit_logs/{logId} {
      allow read: if isAdminOrOwner(resource.data.companyId);
      allow create: if isSignedIn() &&
        belongsToCompany(request.resource.data.companyId);
      allow update, delete: if false; // Denetim kayıtları değiştirilemez
    }
  }
}
